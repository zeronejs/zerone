{
  "name": "@zeronejs/eslint-config-vue3",
  "version": "0.2.1",
  "description": "Zerone ESLint Config",
  "type": "module",
  "engines": {
    "node": ">=12.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    "./recommended": {
      "import": "./dist/recommended.js",
      "types": "./dist/recommended.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "publish:npm": "pnpm build && pnpm publish",
    "publish:npm:beta": "pnpm build && pnpm publish --tag beta --no-git-checks",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "zerone",
    "zeronejs",
    "eslint",
    "vue3"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zeronejs/zerone.git"
  },
  "author": "",
  "license": "MIT",
  "peerDependencies": {
    "eslint": "^10.0.0",
    "prettier": "^3.0.0"
  },
  "dependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.1",
    "@eslint/js": "^10.0.1",
    "@eslint/markdown": "^8.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@vitest/eslint-plugin": "^1.6.17",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jsonc": "^3.1.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-unicorn": "^64.0.0",
    "eslint-plugin-vue": "^10.9.1",
    "globals": "^17.6.0",
    "typescript-eslint": "^8.59.2"
  },
  "devDependencies": {
    "eslint": "^10.3.0"
  }
}
