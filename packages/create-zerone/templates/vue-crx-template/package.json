{
  "name": "crx-demo",
  "displayName": "中文名称",
  "version": "0.0.1",
  "private": true,
  "description": "中文名称",
  "type": "module",
  "scripts": {
    "dev": "run-s clear && cross-env NODE_ENV=development run-p dev:*",
    "dev:prepare": "tsx scripts/prepare.ts",
    "dev:background": "pnpm run build:background -- --mode development",
    "dev:web": "vite --config ./scripts/vite.popup.config.ts",
    "dev:js": "pnpm run build:js -- --mode development",
    "dev:server": "tsx ./scripts/server.ts",
    "build": "cross-env NODE_ENV=production run-s clear build:web build:prepare build:background build:js build:zip",
    "build:prepare": "tsx scripts/prepare.ts",
    "build:background": "vite build --config ./scripts/vite.background.config.ts",
    "build:web": "vite build --config ./scripts/vite.popup.config.ts",
    "build:js": "vite build --config ./scripts/vite.content.config.ts",
    "build:zip": "tsx ./scripts/buildZip.ts",
    "pack:zip": "pnpm run build && rimraf crx.zip && jszip-cli add extension/* -o ./crx.zip",
    "clear": "rimraf --glob extension/dist extension/manifest.json extension.*",
    "api:demo": "zerone api -d -p ./src/api/demo",
    "ai-md": "zerone ai-md",
    "tree": "treee -l 4 --ignore 'node_modules/, .git/, dist/, playground/'",
    "lint": "eslint .",
    "lint:fix": "pnpm run lint --fix",
    "type-check": "vue-tsc --build",
    "prepare": "husky"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@giime/crx": "~1.0.0",
    "@vespaiach/axios-fetch-adapter": "^0.3.1",
    "@vueuse/core": "^14.3.0",
    "@vueuse/integrations": "^14.3.0",
    "axios": "^1.16.1",
    "element-plus": "2.14.0",
    "giime": "~1.0.0",
    "js-cookie": "^3.0.7",
    "lodash-es": "^4.18.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.35",
    "vue-clipboard3": "^2.0.0",
    "vue-router": "^5.0.7"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@ffflorian/jszip-cli": "3.5.0",
    "@iconify-json/ep": "^1.2.4",
    "@tsconfig/node24": "^24.0.4",
    "@types/archiver": "^6.0.4",
    "@types/chrome": "^0.1.42",
    "@types/express": "^5.0.6",
    "@types/fs-extra": "^11.0.4",
    "@types/js-cookie": "^3.0.6",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.9.1",
    "@types/serve-index": "^1.9.4",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/tsconfig": "^0.9.1",
    "@zeronejs/eslint-config-vue3": "^0.2.3",
    "archiver": "^7.0.1",
    "autoprefixer": "^10.5.0",
    "chokidar": "^4.0.3",
    "cross-env": "^7.0.3",
    "eslint": "^10.4.0",
    "express": "^5.2.1",
    "fs-extra": "^11.3.5",
    "husky": "^9.1.7",
    "kolorist": "^1.8.0",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.15",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "rimraf": "^6.1.3",
    "sass": "1.99.0",
    "serve-index": "^1.9.2",
    "tailwindcss": "^3.4.19",
    "terser": "^5.48.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-icons": "23.0.1",
    "unplugin-vue-components": "^32.1.0",
    "vite": "8.0.12",
    "vite-plugin-svg-icons": "^2.0.1",
    "vue-tsc": "^3.3.2"
  }
}
