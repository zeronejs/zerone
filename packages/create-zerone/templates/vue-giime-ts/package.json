{
  "name": "gstore-giime",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "zerone check-deps && vite",
    "build": "vite build",
    "build:develop": "vite build --mode develop",
    "build:test": "vite build --mode test",
    "build:release": "vite build --mode release",
    "preview": "vite preview",
    "build-check": "run-p type-check build-only",
    "type-check": "vue-tsc --build",
    "build-only": "vite build",
    "font": "zerone font_grabber -p ./src/assets/iconfont",
    "api": "zerone api -d -p ./src/api/demo",
    "clean:pkg": "rimraf node_modules",
    "commit": "git-cz",
    "lint": "eslint .",
    "lint:fix": "pnpm run lint --fix",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "prepare": "husky"
  },
  "checkDeps": [],
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@vueuse/core": "^14.3.0",
    "@vueuse/integrations": "^14.3.0",
    "axios": "^1.18.1",
    "dayjs": "^1.11.21",
    "echarts": "^5.6.0",
    "element-plus": "2.14.2",
    "giime": "~1.1.1",
    "js-cookie": "^3.0.8",
    "lodash-es": "^4.18.1",
    "pinia": "^3.0.4",
    "sass": "1.101.0",
    "vue": "^3.5.39",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@tsconfig/node24": "^24.0.4",
    "@types/js-cookie": "^3.0.6",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^26.0.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-istanbul": "^4.1.9",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "@zeronejs/cli": "^3.11.0",
    "@zeronejs/eslint-config-vue3": "^0.2.3",
    "autoprefixer": "^10.5.2",
    "eslint": "^10.6.0",
    "git-cz": "^4.9.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.16",
    "prettier": "^3.9.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "rimraf": "^6.1.3",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-icons": "23.0.1",
    "unplugin-vue-components": "^32.1.0",
    "vite": "8.0.10",
    "vite-plugin-svg-icons": "^2.0.1",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.3.5"
  }
}
